# LLM provider -- set exactly one
BROWSER_USE_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# ANTHROPIC_API_KEY=

# Automatic captcha solving (optional).
# Sign up at https://www.capsolver.com/ for a key.
# If not set the agent falls back to human-in-the-loop.
CAPSOLVER_API_KEY=

# Table size (default 8). Adjusts opening ranges and strategy.
# TABLE_SIZE=8

# Max agent steps per run (default 999999, effectively unlimited).
# Lower this if you want the agent to stop after N steps.
# BROWSER_USE_MAX_STEPS=999999
